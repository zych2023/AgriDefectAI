# App
APP_NAME=SmartAgriAI
DEBUG=true

# MySQL (远程)
DB_HOST=your-mysql-host
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-password
DB_NAME=smart_agri

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# JWT
JWT_SECRET=change-me-to-a-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Upload
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
