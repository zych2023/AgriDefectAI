# ============================================================================
# 智慧农业 RAG — 环境变量配置模板
# ============================================================================
# 使用方式：
#   cp .env.example .env
#   编辑 .env 填入你的真实密钥
# ============================================================================

# -------- LLM 对话模型（DeepSeek）--------
AGRI_LLM_BASE_URL=https://api.deepseek.com
AGRI_LLM_API_KEY=sk-your-deepseek-key-here
AGRI_LLM_MODEL_NAME=deepseek-v4-flash

# -------- Embedding 嵌入模型（阿里云 MaaS）--------
AGRI_EMBEDDING_BASE_URL=https://ws-2fky9xuq9x0cdg19.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
AGRI_EMBEDDING_API_KEY=sk-your-maas-key-here
AGRI_EMBEDDING_MODEL_NAME=text-embedding-v4
# AGRI_EMBEDDING_DIM=1024

# -------- Milvus（可选，默认 127.0.0.1:19530）--------
# MILVUS_URI=http://127.0.0.1:19530
# MILVUS_COLLECTION=agri_knowledge_base
